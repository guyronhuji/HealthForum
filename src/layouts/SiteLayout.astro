---
import '../styles/global.css';
import { locales, pathFor, type LocaleCode, withBase } from '../lib/site';

interface NavItem {
  slug: string;
  label: string;
  href: string;
}

interface AlternateLink {
  lang: LocaleCode;
  href: string;
}

interface Props {
  lang: LocaleCode;
  title: string;
  description: string;
  navItems: NavItem[];
  currentSlug: string;
  alternateLinks: AlternateLink[];
}

const { lang, title, description, navItems, currentSlug, alternateLinks } = Astro.props;
const locale = locales[lang];
const forumLogoSrc = withBase('/logos/forum-logo.png');
const forumFavicon32Src = withBase('/logos/forum-logo-favicon-32.png');
const forumFavicon16Src = withBase('/logos/forum-logo-favicon-16.png');
const navAriaLabel = {
  en: 'Primary',
  he: 'ניווט ראשי',
  ar: 'التنقل الرئيسي',
}[lang];
const affiliatesAriaLabel = {
  en: 'Forum affiliates',
  he: 'ארגוני הפורום',
  ar: 'جهات المنتدى الشريكة',
}[lang];
const useAffiliateCarousel = currentSlug === 'home';
const affiliatePrevLabel = {
  en: 'Previous affiliates',
  he: 'ארגונים קודמים',
  ar: 'الجهات السابقة',
}[lang];
const affiliateNextLabel = {
  en: 'Next affiliates',
  he: 'ארגונים הבאים',
  ar: 'الجهات التالية',
}[lang];
const affiliateLogos = [
  {
    key: 'attaa',
    name: 'Attaa Center',
    href: 'http://www.attaacenter.org/',
    src: withBase('/logos/affiliates/attaa-center.jpg'),
  },
  {
    key: 'jicc',
    name: 'Jerusalem Intercultural Center (JICC)',
    href: 'https://jicc.org.il/',
    src: withBase('/logos/affiliates/jicc.png'),
  },
  {
    key: 'ladaat',
    name: 'Ladaat',
    href: 'https://ladaat.org.il/',
    src: withBase('/logos/affiliates/ladaat.svg'),
  },
  {
    key: 'phr',
    name: 'Physicians for Human Rights Israel',
    href: 'https://phr.org.il/en/',
    src: withBase('/logos/affiliates/phr-israel.png'),
  },
  {
    key: 'acri',
    name: 'Association for Civil Rights in Israel (ACRI)',
    href: 'https://www.acri.org.il/en/',
    src: withBase('/logos/affiliates/acri.png'),
  },
  {
    key: 'iramim',
    name: 'Ir Amim',
    href: 'https://www.ir-amim.org.il/en',
    src: withBase('/logos/affiliates/ir-amim.jpeg'),
  },
  {
    key: 'wacmaan',
    name: 'WAC-MAAN',
    href: 'https://wac-maan.org.il/home-eng/',
    src: withBase('/logos/affiliates/wac-maan.png'),
  },
  {
    key: 'merkazim',
    name: 'Merkazim',
    href: 'https://www.merkazim.org/',
    src: withBase('/logos/affiliates/merkazim.png'),
  },
  {
    key: 'athar',
    name: 'Athar',
    href: 'https://jicc.org.il/projects/public-health/',
    src: withBase('/logos/affiliates/athar.jpeg'),
  },
];
---

<!doctype html>
<html lang={lang} dir={locale.dir}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="32x32" href={forumFavicon32Src} />
    <link rel="icon" type="image/png" sizes="16x16" href={forumFavicon16Src} />
    <link rel="shortcut icon" type="image/png" href={forumFavicon32Src} />
    <link rel="apple-touch-icon" href={forumFavicon32Src} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Heebo:wght@400;500;700&family=Noto+Naskh+Arabic:wght@500;700&family=Public+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <script data-goatcounter="https://eastj.goatcounter.com/count" async src="//gc.zgo.at/count.js"></script>
    <title>{title}</title>
  </head>
  <body class={`lang-${lang}`}>
    <div class="backdrop" aria-hidden="true"></div>
    <header class="site-header">
      <a class="brand" href={pathFor(lang, 'home')}>
        <img class="forum-logo" src={forumLogoSrc} alt={locale.footer} />
        <span class="brand-name">{locale.footer}</span>
      </a>

      <nav class="site-nav" aria-label={navAriaLabel}>
        {
          navItems.map((item) => (
            <a href={item.href} data-active={item.slug === currentSlug ? 'true' : 'false'}>
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="language-switch" aria-label={locale.nav.language}>
        {
          alternateLinks.map((item) => (
            <a href={item.href} data-active={item.lang === lang ? 'true' : 'false'}>
              {locales[item.lang].nativeLabel}
            </a>
          ))
        }
      </div>

      {
        useAffiliateCarousel ? (
          <div
            class="header-affiliates header-affiliates-carousel"
            aria-label={affiliatesAriaLabel}
            data-affiliate-carousel
          >
            <button type="button" class="affiliate-carousel-btn" data-affiliate-prev aria-label={affiliatePrevLabel}>
              ‹
            </button>
            <div class="affiliate-carousel-viewport">
              <div class="affiliate-carousel-track" data-affiliate-track>
                {
                  affiliateLogos.map((logo) => (
                    <div class="affiliate-logo-slide" data-affiliate-slide>
                      <a href={logo.href} target="_blank" rel="noreferrer noopener" class="affiliate-logo-link">
                        <img
                          src={logo.src}
                          alt={logo.name}
                          title={logo.name}
                          class={`affiliate-logo affiliate-logo-${logo.key}`}
                          loading="lazy"
                        />
                      </a>
                    </div>
                  ))
                }
              </div>
            </div>
            <button type="button" class="affiliate-carousel-btn" data-affiliate-next aria-label={affiliateNextLabel}>
              ›
            </button>
          </div>
        ) : (
          <div class="header-affiliates" aria-label={affiliatesAriaLabel}>
            {
              affiliateLogos.map((logo) => (
                <a href={logo.href} target="_blank" rel="noreferrer noopener" class="affiliate-logo-link">
                  <img
                    src={logo.src}
                    alt={logo.name}
                    title={logo.name}
                    class={`affiliate-logo affiliate-logo-${logo.key}`}
                    loading="lazy"
                  />
                </a>
              ))
            }
          </div>
        )
      }
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>{locale.footer}</p>
      <p>{new Date().getFullYear()} · Astro + Pages CMS + GitHub Pages</p>
    </footer>

    <script is:inline>
      (() => {
        const carousels = document.querySelectorAll('[data-affiliate-carousel]');
        if (!carousels.length) return;
        const speedPxPerSecond = 30;

        for (const carousel of carousels) {
          const track = carousel.querySelector('[data-affiliate-track]');
          const slides = Array.from(carousel.querySelectorAll('[data-affiliate-slide]'));
          const prevBtn = carousel.querySelector('[data-affiliate-prev]');
          const nextBtn = carousel.querySelector('[data-affiliate-next]');
          if (!track || slides.length < 2) continue;

          let rafId = 0;
          let lastTs = 0;
          let offset = 0;
          let cycleWidth = 0;
          let stepPx = 0;
          let resizeTimer = 0;

          const getGap = () => {
            const styles = getComputedStyle(track);
            return Number.parseFloat(styles.columnGap || styles.gap || '0') || 0;
          };

          const setTransform = () => {
            track.style.transform = `translateX(-${offset}px)`;
          };

          const normalizeOffset = () => {
            if (cycleWidth <= 0) {
              offset = 0;
              return;
            }
            offset %= cycleWidth;
            if (offset < 0) offset += cycleWidth;
          };

          const removeClones = () => {
            track.querySelectorAll('[data-affiliate-clone]').forEach((node) => node.remove());
          };

          const measureAndClone = (preserveRatio = true) => {
            const previousRatio = cycleWidth > 0 ? offset / cycleWidth : 0;
            removeClones();
            const originals = Array.from(track.querySelectorAll('[data-affiliate-slide]'));
            const gap = getGap();

            const totalWidth = originals.reduce((sum, slide) => sum + slide.getBoundingClientRect().width, 0);
            cycleWidth = totalWidth + gap * originals.length;
            stepPx = (originals[0]?.getBoundingClientRect().width ?? 0) + gap;

            originals.forEach((slide) => {
              const clone = slide.cloneNode(true);
              clone.setAttribute('data-affiliate-clone', 'true');
              track.appendChild(clone);
            });

            if (preserveRatio && cycleWidth > 0) {
              offset = previousRatio * cycleWidth;
            }
            normalizeOffset();
            setTransform();
          };

          const tick = (ts) => {
            if (!lastTs) lastTs = ts;
            const dt = (ts - lastTs) / 1000;
            lastTs = ts;
            offset += speedPxPerSecond * dt;
            normalizeOffset();
            setTransform();
            rafId = window.requestAnimationFrame(tick);
          };

          const start = () => {
            if (rafId || cycleWidth <= 0) return;
            lastTs = 0;
            rafId = window.requestAnimationFrame(tick);
          };

          const stop = () => {
            if (!rafId) return;
            window.cancelAnimationFrame(rafId);
            rafId = 0;
          };

          const nudge = (direction) => {
            if (stepPx <= 0) return;
            offset += direction * stepPx;
            normalizeOffset();
            setTransform();
          };

          prevBtn?.addEventListener('click', () => nudge(-1));
          nextBtn?.addEventListener('click', () => nudge(1));

          window.addEventListener('resize', () => {
            window.clearTimeout(resizeTimer);
            resizeTimer = window.setTimeout(() => {
              measureAndClone(true);
              start();
            }, 120);
          });

          document.addEventListener('visibilitychange', () => {
            if (document.hidden) stop();
            else start();
          });

          measureAndClone(false);
          start();
        }
      })();
    </script>
  </body>
</html>
