---
import { getCollection, render } from 'astro:content';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { alternateLinks, navItems } from '../../lib/content';
import { isLocale, supportedLocales, type LocaleCode, withBase } from '../../lib/site';

export async function getStaticPaths() {
  return supportedLocales.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;

if (!isLocale(langParam)) {
  throw new Error('Unsupported locale');
}

const lang = langParam as LocaleCode;
const allPages = await getCollection('pages');
const home = allPages.find(
  (entry) => entry.data.lang === lang && entry.data.pageSlug === 'home' && !entry.data.draft,
);

if (!home) {
  throw new Error(`Missing home page for language: ${lang}`);
}

const { Content } = await render(home);
const navigation = navItems(allPages, lang);
const alternates = alternateLinks(allPages, 'home');
const chartSlides = [
  {
    title: 'Health service disparities summary',
    src: withBase('/charts/health-forum-charts/chart-gap-summary.html'),
  },
  {
    title: 'Emergency room referrals',
    src: withBase('/charts/health-forum-charts/chart-er-referrals.html'),
  },
  {
    title: 'Speech delay funnel',
    src: withBase('/charts/health-forum-charts/chart-speech-funnel.html'),
  },
  {
    title: 'Screening and physiotherapy trends',
    src: withBase('/charts/health-forum-charts/chart-screening.html'),
  },
];
const whyThisMatters = {
  en: {
    label: 'Why This Matters',
    body: 'Families in East Jerusalem face preventable barriers to timely care. The forum brings evidence, legal advocacy, and community voices together to close these gaps.',
    quote: 'When primary care is hard to access, small problems become emergency visits.',
    cta: 'Read the full 2025 findings →',
  },
  he: {
    label: 'למה זה חשוב',
    body: 'משפחות במזרח ירושלים מתמודדות עם חסמים שניתן למנוע בדרך לטיפול בזמן. הפורום מחבר בין נתונים, פעילות משפטית וקול קהילתי כדי לצמצם את הפערים.',
    quote: 'כשקשה להגיע לרפואת קהילה, בעיות קטנות הופכות לביקורים במיון.',
    cta: 'לקריאת ממצאי 2025 המלאים ←',
  },
  ar: {
    label: 'لماذا هذا مهم',
    body: 'تواجه العائلات في القدس الشرقية عوائق يمكن تجنبها أمام الحصول على رعاية في الوقت المناسب. يجمع المنتدى بين الأدلة والمناصرة القانونية وصوت المجتمع لتقليص هذه الفجوات.',
    quote: 'عندما يصعب الوصول إلى الرعاية الأولية، تتحول المشكلات الصغيرة إلى زيارات طارئة.',
    cta: 'قراءة نتائج 2025 الكاملة ←',
  },
} satisfies Record<
  LocaleCode,
  {
    label: string;
    body: string;
    quote: string;
    cta: string;
  }
>;
---

<SiteLayout
  lang={lang}
  title={home.data.title}
  description={home.data.description}
  navItems={navigation}
  currentSlug="home"
  alternateLinks={alternates}
>
  <article class="page">
    <section class="hero">
      <div class="hero-grid">
        <div>
          <p class="kicker">{home.data.heroKicker}</p>
          <h1>{home.data.heroHeading}</h1>
          <p>{home.data.heroBody}</p>

          <div class="hero-actions">
            <a href={withBase(home.data.secondaryCta.href)}>{home.data.secondaryCta.label}</a>
          </div>

          <section class="why-matters" aria-label={whyThisMatters[lang].label}>
            <p class="why-matters-kicker">{whyThisMatters[lang].label}</p>
            <p class="why-matters-body">{whyThisMatters[lang].body}</p>
            <blockquote class="why-matters-quote">“{whyThisMatters[lang].quote}”</blockquote>
            <a class="why-matters-link" href={withBase(`/${lang}/reports/`)}>
              {whyThisMatters[lang].cta}
            </a>
          </section>
        </div>

        <div class="hero-chart-column">
          <div class="hero-chart-rotator" data-chart-rotator>
            <div class="hero-chart-viewport">
              {
                chartSlides.map((chart, index) => (
                  <iframe
                    class={`hero-chart-frame${index === 0 ? ' is-active' : ''}`}
                    src={chart.src}
                    title={chart.title}
                    loading={index === 0 ? 'eager' : 'lazy'}
                  ></iframe>
                ))
              }
            </div>
            <div class="hero-chart-nav">
              {
                chartSlides.map((_, index) => (
                  <button
                    type="button"
                    class={`hero-chart-dot${index === 0 ? ' is-active' : ''}`}
                    data-chart-dot={index}
                    aria-label={`Show chart ${index + 1}`}
                    aria-pressed={index === 0 ? 'true' : 'false'}
                  ></button>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="block">
      <h2>{home.data.title}</h2>
      <div class="highlights">
        {
          home.data.highlights.map((item) => (
            <article class="highlight">
              <h3>{item.title}</h3>
              <p>{item.body}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="block">
      <h2>{home.data.partnersTitle}</h2>
      <ul class="partner-list">
        {
          home.data.partners.map((partner) => <li>{partner}</li>)
        }
      </ul>
    </section>

    <section class="markdown">
      <Content />
    </section>

    {home.data.sourceNote && <p class="source-note">{home.data.sourceNote}</p>}
  </article>
</SiteLayout>

<script is:inline>
  (() => {
    const rotators = document.querySelectorAll('[data-chart-rotator]');
    const switchEveryMs = 5000;
    const transitionMs = 680;

    for (const rotator of rotators) {
      const viewport = rotator.querySelector('.hero-chart-viewport');
      const frames = Array.from(rotator.querySelectorAll('.hero-chart-frame'));
      const dots = Array.from(rotator.querySelectorAll('.hero-chart-dot'));
      if (frames.length < 2) continue;

      let currentIndex = 0;
      let intervalId = null;
      let isAnimating = false;
      const measuredHeights = new Map();

      const measureFrame = (frame) => {
        try {
          const doc = frame.contentDocument;
          if (!doc) return;
          const height = Math.max(
            doc.body?.scrollHeight ?? 0,
            doc.documentElement?.scrollHeight ?? 0,
            doc.body?.offsetHeight ?? 0,
            doc.documentElement?.offsetHeight ?? 0,
          );
          if (height > 0) measuredHeights.set(frame, height);
        } catch {
          // ignore read errors
        }
      };

      const syncFixedViewportHeight = () => {
        if (!viewport) return;
        let tallest = 0;
        frames.forEach((frame) => {
          measureFrame(frame);
          const measured = measuredHeights.get(frame) ?? 0;
          if (measured > tallest) tallest = measured;
        });
        if (tallest > 0) {
          // Keep a small breathing room so bottom labels aren't clipped.
          viewport.style.height = `${tallest + 8}px`;
        }
      };

      const stopRotation = () => {
        if (intervalId) {
          window.clearInterval(intervalId);
          intervalId = null;
        }
      };

      const goTo = (nextIndex) => {
        if (isAnimating) return;
        if (nextIndex === currentIndex) return;
        const currentFrame = frames[currentIndex];
        const nextFrame = frames[nextIndex];

        isAnimating = true;
        nextFrame.classList.add('is-next');

        window.requestAnimationFrame(() => {
          window.requestAnimationFrame(() => {
            currentFrame.classList.add('is-leaving');
            nextFrame.classList.add('is-entering');
          });
        });

        dots[currentIndex]?.classList.remove('is-active');
        dots[currentIndex]?.setAttribute('aria-pressed', 'false');
        dots[nextIndex]?.classList.add('is-active');
        dots[nextIndex]?.setAttribute('aria-pressed', 'true');

        window.setTimeout(() => {
          currentFrame.classList.remove('is-active', 'is-leaving');
          nextFrame.classList.remove('is-next', 'is-entering');
          nextFrame.classList.add('is-active');
          currentIndex = nextIndex;
          isAnimating = false;
        }, transitionMs);
      };

      const goToNext = () => {
        const nextIndex = (currentIndex + 1) % frames.length;
        goTo(nextIndex);
      };

      const startRotation = () => {
        stopRotation();
        intervalId = window.setInterval(goToNext, switchEveryMs);
      };

      frames.forEach((frame) => {
        frame.addEventListener('load', () => {
          measureFrame(frame);
          syncFixedViewportHeight();
        });
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          goTo(index);
          startRotation();
        });
      });

      rotator.addEventListener('mouseenter', stopRotation);
      rotator.addEventListener('mouseleave', startRotation);
      rotator.addEventListener('focusin', stopRotation);
      rotator.addEventListener('focusout', startRotation);
      window.addEventListener('resize', syncFixedViewportHeight);

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopRotation();
        else startRotation();
      });

      syncFixedViewportHeight();
      window.setTimeout(syncFixedViewportHeight, 1200);
      startRotation();
    }
  })();
</script>
