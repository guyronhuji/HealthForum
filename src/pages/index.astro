---
const base = import.meta.env.BASE_URL ?? '/';
---

<!doctype html>
<html lang="en" data-base={base}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="refresh" content={`0; url=${base}en/`} />
    <title>Redirecting...</title>
  </head>
  <body>
    <p>Redirecting...</p>
    <script>
      const base = document.documentElement.dataset.base || '/';
      const langs = Array.isArray(navigator.languages) ? navigator.languages : [navigator.language];
      const first = (langs[0] || '').toLowerCase();
      let target = `${base}en/`;

      if (first.startsWith('he')) target = `${base}he/`;
      if (first.startsWith('ar')) target = `${base}ar/`;

      window.location.replace(target);
    </script>
  </body>
</html>
